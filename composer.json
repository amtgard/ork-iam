{
  "name"  : "amtgard/ork-iam",
  "type"  : "library",
  "homepage": "https://github.com/amtgard/ork-iam",
  "license" : "MIT",
  "description": "Amtgard ORK IAM",
  "repositories": [
    {
      "type": "path",
      "url": "../ork-iam-orn-definitions",
      "options": {
        "symlink": true
      }
    }
  ],
  "require-dev": {
    "amtgard/ork-iam-orn-definitions": "@dev",
    "phake/phake": "^4.5",
    "phpunit/phpunit": "^11.3"
  },
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "monolog/monolog": "^3.7",
    "amtgard/phpunit-extensions": "^1.0",
    "amtgard/builder-traits": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Amtgard\\IAM\\": "./src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\Amtgard\\IAM\\": "./tests/"
    }
  },
  "bin": [
    "./bin/"
  ],
  "extra": {
    "branch-alias": {
      "dev-1.x": "1.4-dev"
    }
  }
}
